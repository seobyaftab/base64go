        "step": [
          { "@type": "HowToStep", "position": 1, "name": "Type or paste your text", "text": "Type or paste your text on base64go.com." },
          { "@type": "HowToStep", "position": 2, "name": "Switch to Encode mode", "text": "Switch the mode to Encode." },
          { "@type": "HowToStep", "position": 3, "name": "Copy the Base64 output", "text": "The Base64 output appears instantly in the right panel. Click Copy to grab the encoded string." },
          { "@type": "HowToStep", "position": 4, "name": "JavaScript encoding", "text": "Use JavaScript's btoa() function for simple ASCII text. For UTF-8 safe encoding including emojis, use TextEncoder first then btoa()." },
          { "@type": "HowToStep", "position": 5, "name": "Python encoding", "text": "Use Python's base64.b64encode() with text.encode('utf-8') to handle any Unicode text including emojis and non-Latin scripts." },
