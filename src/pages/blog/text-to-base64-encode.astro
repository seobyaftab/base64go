            "acceptedAnswer": { "@type": "Answer", "text": "Yes. Any Unicode text — including emojis, Chinese, Arabic, Cyrillic — can be Base64-encoded. You must encode the text as UTF-8 bytes first. Our online tool handles this automatically." }
