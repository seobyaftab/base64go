    <div class="mt-12 border-t border-hairline pt-8">
      <h2 class="text-[18px] font-semibold leading-7 tracking-[-0.54px] text-ink mb-4">Related Guides</h2>
      <div class="grid gap-3 sm:grid-cols-2">
