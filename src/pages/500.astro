---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="flex items-center justify-center px-4 py-32 sm:py-40">
    <div class="text-center">
      <p class="text-[80px] font-semibold leading-none tracking-[-4px] text-ink font-mono">500</p>
      <h1 class="mt-4 text-[24px] font-semibold leading-8 tracking-[-0.96px] text-ink">
        Something went wrong.
      </h1>
      <p class="mt-2 text-[16px] leading-6 text-body">
        An unexpected error occurred. Please try again in a moment.
      </p>
      <a
        href="/"
        class="mt-6 inline-flex items-center gap-2 rounded-full bg-ink px-6 py-3 text-[16px] font-medium leading-6 text-canvas no-underline transition-all hover:opacity-90"
      >
        Back to the Tool
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </section>
</Layout>
