---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/what-is-base64/', label: 'Guide' },
  { href: '/about/', label: 'About' },
];
---

<header
  class="sticky top-0 z-50 h-16 flex items-center border-b border-hairline bg-canvas/80 backdrop-blur-md"
>
  <nav
    class="mx-auto flex w-full max-w-[1400px] items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 text-[14px] font-medium tracking-[-0.28px] text-ink no-underline"
    >
      <img src="/icon.svg" alt="base64go" width="22" height="22" class="block" />
      <span>base64go</span>
    </a>

    <!-- Center links -->
    <div class="hidden sm:flex items-center gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="rounded-full px-3 py-2 text-[14px] leading-5 tracking-[-0.28px] text-body no-underline transition-colors hover:text-ink hover:bg-canvas-soft-2"
          >
            {link.label}
          </a>
        ))
      }
    </div>

    <!-- Right actions -->
    <div class="flex items-center gap-2">
      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="flex h-8 w-8 items-center justify-center rounded-full border border-hairline bg-canvas text-ink transition-colors hover:bg-canvas-soft-2"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg id="theme-sun" class="hidden dark:block" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" />
          <line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" />
          <line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg id="theme-moon" class="block dark:hidden" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        type="button"
        aria-label="Toggle menu"
        class="flex sm:hidden h-8 w-8 items-center justify-center rounded-full border border-hairline bg-canvas text-ink"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden absolute top-16 left-0 right-0 border-b border-hairline bg-canvas p-4 sm:hidden"
  >
    <div class="flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="rounded-lg px-3 py-2.5 text-[14px] text-body no-underline hover:bg-canvas-soft-2 hover:text-ink"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  // Theme toggle
  const toggle = document.getElementById('theme-toggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    });
  }

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  if (menuBtn && menu) {
    menuBtn.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  }
</script>
